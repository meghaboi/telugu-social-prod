# Core
NODE_ENV=development
APP_ENV=local

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000

# Auth/OTP
OTP_PROVIDER=mock
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30

# Database/Cache
DATABASE_URL=postgresql://user:password@localhost:5432/telugu_social
REDIS_URL=redis://localhost:6379

# Storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Observability
SENTRY_DSN=
LOG_LEVEL=info

# Feature Flags
FEATURE_FLAG_PROVIDER=local

